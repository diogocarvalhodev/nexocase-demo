# =========================
# Docker Compose / Backend
# =========================
POSTGRES_USER=nexocase_user
POSTGRES_PASSWORD=nexocase_demo
POSTGRES_DB=nexocase_db

DATABASE_URL=postgresql://nexocase_user:nexocase_demo@db:5432/nexocase_db
SECRET_KEY=change-me-demo-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_NAME=nexocase_refresh_token
CSRF_COOKIE_NAME=nexocase_csrf_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
ENABLE_AUDIT_RETENTION_SCHEDULE=true
AUDIT_RETENTION_INTERVAL_HOURS=24
AUDIT_RETENTION_DEFAULT_DAYS=365

CORS_ALLOWED_ORIGINS=http://localhost:3000
ENABLE_IP_RESTRICTION=false
ALLOWED_NETWORK_CIDR=127.0.0.1/32
TRUST_PROXY_HEADERS=false
ENABLE_HSTS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_REQUESTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_EXPORT_REQUESTS=10
RATE_LIMIT_ADMIN_EXPORT_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD_LOGO_REQUESTS=5
RATE_LIMIT_UPLOAD_LOGO_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_REQUESTS=2000
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
ACCOUNT_LOCKOUT_ENABLED=true
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
PASSWORD_MAX_AGE_DAYS=90
DEMO_MODE=true
DEMO_AUTO_SEED=true
DEMO_DISABLE_EMAIL=true

UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
DEFAULT_TENANT_SLUG=default
TENANT_HEADER_NAME=X-Tenant

# =========================
# Frontend
# =========================
NEXT_PUBLIC_API_URL=/backend
INTERNAL_API_URL=http://backend:8000
FRONTEND_PORT=3000
NEXT_PUBLIC_DEFAULT_TENANT=default
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_SHOWCASE_MODE=false
